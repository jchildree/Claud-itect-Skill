{
  "version": "2.0",
  "requiredSkills": [
    "caveman", "audit", "safe-push", "writing-skills", "using-superpowers",
    "llm-wiki", "memory-to-vault"
  ],
  "requiredHooks": [
    "caveman-activate.js", "caveman-mode-tracker.js", "check-encoding.js"
  ],
  "hookWiring": [
    { "event": "SessionStart",     "file": "caveman-activate.js" },
    { "event": "UserPromptSubmit", "file": "caveman-mode-tracker.js" },
    { "event": "PostToolUse",      "matcher": "Write|Edit", "file": "check-encoding.js" }
  ]
}
